# Copy this file to .env and fill in your actual values.
# Never commit .env — it is gitignored.

# ── Local SQLite (quick local dev, no account needed) ────────────
# DATABASE_URL="file:./dev.db"

# ── Neon / Vercel Postgres (required for Vercel deployment) ──────
# Get these from https://neon.tech → your project → Connection Details
POSTGRES_PRISMA_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
