datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Expense {
  id          String   @id @default(uuid())
  amount      Float
  description String
  category    String
  subcategory String
  date        DateTime
  note        String?
  createdAt   DateTime @default(now())
}